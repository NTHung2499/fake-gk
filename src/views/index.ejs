<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#fbbc04">
    <title>Fake GK</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/styles.css">
    <script>
      (() => {
        const saved = localStorage.getItem("fake-gk-theme");
        const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = saved || (systemDark ? "dark" : "light");
      })();
    </script>
  </head>
  <body>
    <% const pinnedNotes = notes.filter((note) => note.is_pinned); %>
    <% const otherNotes = notes.filter((note) => !note.is_pinned); %>
    <header class="appbar">
      <div class="appbar-left">
        <button class="icon-button appbar-icon" type="button" aria-label="Main menu" title="Main menu">
          <span aria-hidden="true">&#9776;</span>
        </button>
        <div class="brand">
          <div class="brand-mark">K</div>
          <h1>Keep</h1>
        </div>
      </div>
      <label class="search-shell" aria-label="Search notes">
        <span class="search-icon" aria-hidden="true">&#128269;</span>
        <input type="search" placeholder="Search" aria-label="Search">
      </label>
      <div class="appbar-right">
        <button class="icon-button appbar-icon" type="button" aria-label="Refresh" title="Refresh">
          <span aria-hidden="true">&#8635;</span>
        </button>
        <button class="icon-button appbar-icon" type="button" aria-label="List view" title="List view">
          <span aria-hidden="true">&#9783;</span>
        </button>
        <button class="icon-button appbar-icon" type="button" data-theme-toggle aria-label="Toggle dark mode" title="Toggle dark mode" aria-pressed="false">
          <span data-theme-icon aria-hidden="true">&#9789;</span>
        </button>
        <button class="icon-button appbar-icon" type="button" aria-label="Settings" title="Settings">
          <span aria-hidden="true">&#9881;</span>
        </button>
        <div class="avatar" title="Profile">GK</div>
      </div>
    </header>

    <div class="layout-shell">
      <aside class="left-rail" aria-label="Primary navigation">
        <button class="rail-item rail-item-active" type="button">
          <span aria-hidden="true">&#128221;</span>
          <span>Notes</span>
        </button>
        <button class="rail-item" type="button">
          <span aria-hidden="true">&#128230;</span>
          <span>Archive</span>
        </button>
      </aside>

      <main class="main-content">
      <form class="composer" action="/notes" method="post" data-composer data-composer-open="false">
        <div class="composer-collapsed">Take a note...</div>
        <div class="composer-fields">
          <input name="title" type="text" placeholder="Title" maxlength="255" aria-label="Note title" data-composer-title>
          <textarea name="body" rows="3" placeholder="Take a note..." aria-label="Note body"></textarea>
        </div>
        <div class="composer-actions">
          <div class="composer-actions-left">
            <button class="icon-button appbar-icon" type="button" aria-label="Checklist" title="Checklist">
              <span aria-hidden="true">&#9744;</span>
            </button>
            <button class="icon-button appbar-icon" type="button" aria-label="Brush" title="Brush">
              <span aria-hidden="true">&#9998;</span>
            </button>
            <button class="icon-button appbar-icon" type="button" aria-label="Image" title="Image">
              <span aria-hidden="true">&#128247;</span>
            </button>
            <label class="composer-color">
              <span>Color</span>
              <select name="color" aria-label="Note color">
              <% colors.forEach((color) => { %>
                <option value="<%= color %>"><%= color %></option>
              <% }) %>
            </select>
            </label>
          </div>
          <div class="composer-actions-right">
            <button class="ghost-button" type="button" data-composer-close>Close</button>
            <button class="primary-button" type="submit">Add note</button>
          </div>
        </div>
      </form>

      <section class="section">
        <h2 class="section-title">PINNED</h2>
        <% if (pinnedNotes.length === 0) { %>
          <p class="section-empty">No pinned notes.</p>
        <% } else { %>
          <div class="note-grid">
          <% pinnedNotes.forEach((note) => { %>
            <%- include("partials/note-card", { note, colors }) %>
          <% }) %>
          </div>
        <% } %>
      </section>

      <section class="section">
        <h2 class="section-title">OTHERS</h2>
        <% if (otherNotes.length === 0) { %>
          <p class="section-empty">No notes.</p>
        <% } else { %>
          <div class="note-grid">
          <% otherNotes.forEach((note) => { %>
            <%- include("partials/note-card", { note, colors }) %>
          <% }) %>
          </div>
        <% } %>
      </section>

      <section class="section section-archive">
        <h2 class="section-title">ARCHIVE</h2>
        <% if (archivedNotes.length === 0) { %>
          <p class="section-empty">No archived notes.</p>
        <% } else { %>
          <div class="note-grid">
          <% archivedNotes.forEach((note) => { %>
            <%- include("partials/note-card", { note, colors }) %>
          <% }) %>
          </div>
        <% } %>
      </section>
      </main>
    </div>
    <script src="/theme.js" defer></script>
    <script src="/ui.js" defer></script>
  </body>
</html>
