<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#d6a725">
    <title>Fake GK</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/styles.css">
    <script>
      (() => {
        const saved = localStorage.getItem("fake-gk-theme");
        const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = saved || (systemDark ? "dark" : "light");
      })();
    </script>
  </head>
  <body>
    <% const pinnedNotes = notes.filter((note) => note.is_pinned); %>
    <% const recentNotes = notes.filter((note) => !note.is_pinned); %>
    <% const totalNotes = notes.length + archivedNotes.length; %>

    <header class="workspace-header">
      <div class="brand-lockup">
        <div class="brand-mark">N</div>
        <div>
          <h1>Notes</h1>
          <p>Personal workspace</p>
        </div>
      </div>

      <label class="search-shell" aria-label="Search notes">
        <%- include("partials/icon", { icon: "search" }) %>
        <input type="search" placeholder="Search notes" aria-label="Search notes" data-note-search>
      </label>

      <div class="header-actions">
        <button class="icon-button" type="button" aria-label="Refresh" title="Refresh">
          <%- include("partials/icon", { icon: "refresh" }) %>
        </button>
        <button class="icon-button" type="button" data-theme-toggle aria-label="Toggle dark mode" title="Toggle dark mode" aria-pressed="false">
          <span class="theme-icon theme-icon-moon" data-theme-icon="moon"><%- include("partials/icon", { icon: "moon" }) %></span>
          <span class="theme-icon theme-icon-sun" data-theme-icon="sun"><%- include("partials/icon", { icon: "sun" }) %></span>
        </button>
        <div class="avatar" title="Profile">GK</div>
      </div>
    </header>

    <div class="workspace-shell">
      <aside class="workspace-nav" aria-label="Workspace navigation">
        <button class="nav-item is-active" type="button">
          <span class="nav-icon"><%- include("partials/icon", { icon: "note" }) %></span>
          <span>Notes</span>
          <strong><%= notes.length %></strong>
        </button>
        <button class="nav-item" type="button">
          <span class="nav-icon"><%- include("partials/icon", { icon: "archive" }) %></span>
          <span>Archived</span>
          <strong><%= archivedNotes.length %></strong>
        </button>
      </aside>

      <main class="workspace-main">
        <section class="capture-panel" aria-label="Create note">
          <div class="capture-copy">
            <p class="eyebrow">Quick capture</p>
            <h2>Keep the thought while it is still fresh.</h2>
          </div>

          <form class="composer" action="/notes" method="post" data-composer data-composer-open="false">
            <div class="composer-collapsed">Start a new note</div>
            <div class="composer-fields">
              <input name="title" type="text" placeholder="Title" maxlength="255" aria-label="Note title" data-composer-title>
              <textarea name="body" rows="3" placeholder="Write the details..." aria-label="Note body"></textarea>
            </div>
            <div class="composer-actions">
              <div class="composer-tools">
                <button class="icon-button" type="button" aria-label="Checklist" title="Checklist">
                  <%- include("partials/icon", { icon: "check-square" }) %>
                </button>
                <button class="icon-button" type="button" aria-label="Color palette" title="Color palette">
                  <%- include("partials/icon", { icon: "palette" }) %>
                </button>
                <button class="icon-button" type="button" aria-label="Image" title="Image">
                  <%- include("partials/icon", { icon: "image" }) %>
                </button>
                <label class="color-control">
                  <select name="color" aria-label="Note color">
                    <% colors.forEach((color) => { %>
                      <option value="<%= color %>"><%= color %></option>
                    <% }) %>
                  </select>
                </label>
              </div>
              <div class="composer-submit">
                <button class="ghost-button" type="button" data-composer-close>Close</button>
                <button class="primary-button" type="submit">Add note</button>
              </div>
            </div>
          </form>
        </section>

        <section class="summary-strip" aria-label="Workspace summary">
          <div>
            <span>Total</span>
            <strong><%= totalNotes %></strong>
          </div>
          <div>
            <span>Pinned</span>
            <strong><%= pinnedNotes.length %></strong>
          </div>
          <div>
            <span>Archived</span>
            <strong><%= archivedNotes.length %></strong>
          </div>
        </section>

        <section class="note-section" data-note-section>
          <div class="section-header">
            <div>
              <p class="eyebrow">Priority</p>
              <h2>Pinned</h2>
            </div>
            <span><%= pinnedNotes.length %></span>
          </div>
          <p class="section-empty" data-section-empty <%= pinnedNotes.length > 0 ? "hidden" : "" %>>No pinned notes yet.</p>
          <div class="note-grid">
            <% pinnedNotes.forEach((note) => { %>
              <%- include("partials/note-card", { note, colors }) %>
            <% }) %>
          </div>
        </section>

        <section class="note-section" data-note-section>
          <div class="section-header">
            <div>
              <p class="eyebrow">Latest</p>
              <h2>Recent</h2>
            </div>
            <span><%= recentNotes.length %></span>
          </div>
          <p class="section-empty" data-section-empty <%= recentNotes.length > 0 ? "hidden" : "" %>>No recent notes yet.</p>
          <div class="note-grid">
            <% recentNotes.forEach((note) => { %>
              <%- include("partials/note-card", { note, colors }) %>
            <% }) %>
          </div>
        </section>

        <section class="note-section" data-note-section>
          <div class="section-header">
            <div>
              <p class="eyebrow">Saved away</p>
              <h2>Archived</h2>
            </div>
            <span><%= archivedNotes.length %></span>
          </div>
          <p class="section-empty" data-section-empty <%= archivedNotes.length > 0 ? "hidden" : "" %>>No archived notes.</p>
          <div class="note-grid">
            <% archivedNotes.forEach((note) => { %>
              <%- include("partials/note-card", { note, colors }) %>
            <% }) %>
          </div>
        </section>
      </main>
    </div>

    <script src="/theme.js" defer></script>
    <script src="/ui.js" defer></script>
  </body>
</html>
