<article class="note note-<%= note.color %>" data-note-card data-note-id="<%= note.id %>" data-expanded="false" tabindex="0">
  <form action="/notes/<%= note.id %>/pin" method="post" class="note-pin-form">
    <% if (!note.is_archived) { %>
      <button class="icon-button note-pin" type="submit" title="<%= note.is_pinned ? "Unpin note" : "Pin note" %>" aria-label="<%= note.is_pinned ? "Unpin note" : "Pin note" %>">
        <span aria-hidden="true"><%= note.is_pinned ? "📌" : "📍" %></span>
      </button>
    <% } %>
  </form>

  <div class="note-preview" data-note-preview>
    <% if (note.title) { %>
      <h3><%= note.title %></h3>
    <% } %>
    <% if (note.body) { %>
      <p><%= note.body %></p>
    <% } %>
    <% if (!note.title && !note.body) { %>
      <p class="note-muted">Empty note</p>
    <% } %>
  </div>

  <form action="/notes/<%= note.id %>" method="post" class="note-form" data-note-form>
    <input name="title" value="<%= note.title %>" maxlength="255" placeholder="Title" aria-label="Edit title">
    <textarea name="body" rows="5" placeholder="Take a note" aria-label="Edit body"><%= note.body %></textarea>
    <div class="note-footer">
      <label class="note-color">
        <span>Color</span>
        <select name="color" aria-label="Change color">
          <% colors.forEach((color) => { %>
            <option value="<%= color %>" <%= color === note.color ? "selected" : "" %>><%= color %></option>
          <% }) %>
        </select>
      </label>
      <div class="note-footer-actions">
        <button class="ghost-button" type="button" data-note-close>Close</button>
        <button class="save-button" type="submit">Save</button>
      </div>
    </div>
  </form>

  <div class="note-actions">
    <form action="/notes/<%= note.id %>/archive" method="post">
      <button class="icon-button" type="submit" title="<%= note.is_archived ? "Restore note" : "Archive note" %>" aria-label="<%= note.is_archived ? "Restore note" : "Archive note" %>">
        <span aria-hidden="true"><%= note.is_archived ? "↩" : "🗄" %></span>
      </button>
    </form>
    <form action="/notes/<%= note.id %>/delete" method="post">
      <button type="submit" class="icon-button danger" title="Delete note" aria-label="Delete note">
        <span aria-hidden="true">🗑</span>
      </button>
    </form>
  </div>
</article>
